---
// Ten neutral, monochrome geometric placeholder marks (never real brands).
// Each inherits color via currentColor so every concept can tint them.
// Decorative: aria-hidden, not focusable.
const S = { "aria-hidden": "true", focusable: "false", viewBox: "0 0 48 48", xmlns: "http://www.w3.org/2000/svg" };
---
<span class="mark"><svg {...S}><circle cx="24" cy="24" r="15" fill="none" stroke="currentColor" stroke-width="2.5"/><circle cx="24" cy="24" r="4" fill="currentColor"/></svg></span>
<span class="mark"><svg {...S}><path d="M24 8 L41 39 L7 39 Z" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/></svg></span>
<span class="mark"><svg {...S}><rect x="12" y="12" width="24" height="24" rx="2" fill="none" stroke="currentColor" stroke-width="2.5" transform="rotate(45 24 24)"/></svg></span>
<span class="mark"><svg {...S}><path d="M24 7 L38 15 L38 33 L24 41 L10 33 L10 15 Z" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linejoin="round"/></svg></span>
<span class="mark"><svg {...S}><path d="M14 34 A16 16 0 0 1 34 14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/><path d="M18 34 A10 10 0 0 1 34 20" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"/></svg></span>
<span class="mark"><svg {...S}><path d="M24 10 V38 M10 24 H38" stroke="currentColor" stroke-width="4" stroke-linecap="round"/></svg></span>
<span class="mark"><svg {...S}><rect x="11" y="24" width="6" height="14" rx="1.5" fill="currentColor"/><rect x="21" y="16" width="6" height="22" rx="1.5" fill="currentColor"/><rect x="31" y="10" width="6" height="28" rx="1.5" fill="currentColor"/></svg></span>
