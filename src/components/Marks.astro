<span class="mark"><svg {...S}><path d="M14 12 L26 24 L14 36 M24 12 L36 24 L24 36" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/></svg></span>
<span class="mark"><svg {...S}><rect x="11" y="11" width="11" height="11" rx="1.5" fill="currentColor"/><rect x="26" y="11" width="11" height="11" rx="1.5" fill="none" stroke="currentColor" stroke-width="2.5"/><rect x="11" y="26" width="11" height="11" rx="1.5" fill="none" stroke="currentColor" stroke-width="2.5"/><rect x="26" y="26" width="11" height="11" rx="1.5" fill="currentColor"/></svg></span>
