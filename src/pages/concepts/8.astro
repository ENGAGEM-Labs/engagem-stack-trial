---
import ConceptLayout from "../../layouts/ConceptLayout.astro";
import Marquee from "../../components/Marquee.astro";
import { WORDMARK, NAV, CTA, HERO, MARQUEE_CAPTION, WHY } from "../../data/concept.js";
const fonts = [
  "https://fonts.googleapis.com/css2?family=Syncopate:wght@400;700&family=Space+Mono:wght@400;700&display=swap",
];
---
<ConceptLayout title="ENGAGEM Concept 8: Kinetic Typography" description="ENGAGEM home page concept: kinetic typography direction." fonts={fonts} themeColor="#07344d" scheme="dark">
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="site-header">
    <a class="wordmark" href="#">{WORDMARK}</a>
    <nav class="nav" aria-label="Primary">
      <ul>{NAV.map((i) => <li><a href="#">{i}</a></li>)}</ul>
    </nav>
    <a class="cta" href="#">{CTA}</a>
  </header>

  <main id="main">
    <section class="hero">
      <p class="eyebrow" aria-hidden="true">[ systems.in.motion ]</p>
      <h1><span class="kinetic">ENGAGE</span> <span class="rest">your market.</span></h1>
      <p class="hero__support">{HERO.support}</p>
      <a class="cta cta--hero" href="#">{CTA}</a>
    </section>

    <section class="trust" aria-labelledby="trust-cap">
      <p class="trust__caption" id="trust-cap">{MARQUEE_CAPTION}</p>
      <Marquee />
    </section>

    <section class="why" aria-labelledby="why-h">
      <h2 id="why-h">{WHY.h2}</h2>
      <ul class="benefits">
        {WHY.benefits.map((b, idx) => (
          <li>
            <span class="idx" aria-hidden="true">{`0${idx + 1}`}</span>
            <h3>{b.heading}</h3>
            <p>{b.body}</p>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <style is:global>
    :root { --ink: #07344d; --ink-2: #0a3f5c; --green: #18d794; --paper: #eaf6f2; --dim: #9fc3cf; }
    body { background: var(--ink); color: #dff1f4;
      font-family: "Space Mono", monospace; line-height: 1.6; }
    .site-header { display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem 1.75rem;
      padding: 1.3rem clamp(1.25rem, 5vw, 4rem); border-bottom: 1px solid rgba(255,255,255,0.12); }
    .wordmark { font-family: "Syncopate", sans-serif; font-weight: 700; font-size: 1.05rem;
      letter-spacing: 0.14em; text-decoration: none; margin-right: auto; color: #fff; }
    .nav ul { list-style: none; display: flex; flex-wrap: wrap; gap: 1.1rem; padding: 0; }
    .nav a { text-decoration: none; font-size: 0.82rem; color: var(--dim); letter-spacing: 0.04em; }
    .nav a:hover { color: var(--green); }
    .cta { font-family: "Space Mono", monospace; text-decoration: none; font-weight: 700;
      font-size: 0.85rem; background: var(--green); color: var(--ink);
      padding: 0.6rem 1.2rem; letter-spacing: 0.04em; transition: box-shadow 150ms ease; }
    .cta:hover { box-shadow: 0 0 0 3px rgba(24,215,148,0.35); }

    main { max-width: 1200px; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 4rem); }

    .hero { padding: clamp(3.5rem, 9vw, 7rem) 0 clamp(3rem, 7vw, 5rem); }
    .eyebrow { font-size: 0.82rem; letter-spacing: 0.22em; color: var(--green);
      margin-bottom: 1.75rem; text-transform: uppercase; }
    h1 { font-family: "Syncopate", sans-serif; font-weight: 700; letter-spacing: -0.01em;
      line-height: 1.02; display: flex; flex-direction: column; gap: 0.35rem; }
    .kinetic { font-size: clamp(2.6rem, 12vw, 8rem); color: var(--green);
      text-shadow: 0.12em 0 rgba(24,215,148,0.35), 0.24em 0 rgba(24,215,148,0.16);
      animation: drift 3.6s ease-in-out infinite; transform-origin: left; }
    .rest { font-size: clamp(1.6rem, 7vw, 4.5rem); color: #fff; }
    @keyframes drift { 0%, 100% { transform: translateX(0); } 50% { transform: translateX(0.1em); } }
    .hero__support { font-size: clamp(1.05rem, 2.3vw, 1.35rem); max-width: 46ch;
      margin: 2rem 0 2.5rem; color: #bfdbe2; }
    .cta--hero { display: inline-block; font-size: 1.05rem; padding: 0.95rem 1.9rem; }

    .trust { padding: clamp(3rem, 7vw, 4.5rem) 0; text-align: center;
      border-block: 1px solid rgba(255,255,255,0.12); }
    .trust__caption { font-size: 0.8rem; letter-spacing: 0.14em; text-transform: uppercase;
      color: var(--dim); margin-bottom: 2rem; }
    .trust .mark { --mark-color: var(--green); --mark-opacity: 0.6; --mark-size: 42px; }

    .why { padding: clamp(3.5rem, 9vw, 6rem) 0 clamp(4.5rem, 11vw, 8rem); }
    h2 { font-family: "Syncopate", sans-serif; font-weight: 700; font-size: clamp(1.6rem, 4.5vw, 2.8rem);
      line-height: 1.15; letter-spacing: -0.01em; color: #fff;
      margin-bottom: clamp(2.25rem, 5vw, 3.25rem); max-width: 18ch; }
    .benefits { list-style: none; padding: 0; display: grid; gap: 1.25rem; grid-template-columns: 1fr; }
    .benefits li { border: 1px solid rgba(255,255,255,0.14); background: var(--ink-2);
      padding: 1.75rem; }
    .idx { font-family: "Syncopate", sans-serif; font-weight: 700; color: var(--green);
      font-size: 1rem; display: block; margin-bottom: 1rem; letter-spacing: 0.1em; }
    .benefits h3 { font-family: "Syncopate", sans-serif; font-weight: 700; font-size: 1.05rem;
      line-height: 1.3; color: #fff; margin-bottom: 0.75rem; letter-spacing: -0.01em; }
    .benefits p { color: #bfdbe2; font-size: 0.98rem; }
    @media (min-width: 860px) { .benefits { grid-template-columns: repeat(3, 1fr); gap: 1.5rem; } }
  </style>
</ConceptLayout>
