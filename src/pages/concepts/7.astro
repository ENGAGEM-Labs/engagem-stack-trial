---
import ConceptLayout from "../../layouts/ConceptLayout.astro";
import Marquee from "../../components/Marquee.astro";
import { WORDMARK, NAV, CTA, HERO, MARQUEE_CAPTION, WHY } from "../../data/concept.js";
// Direction 7 swaps Inter-Tight -> Archivo (non-Inter grotesque) per frontend-design.
const fonts = [
  "https://fonts.googleapis.com/css2?family=Archivo:wght@600;700;800;900&family=Playfair+Display:ital,wght@0,600;1,500;1,600&display=swap",
];
---
<ConceptLayout title="ENGAGEM Concept 7: Bold Typography Poster" description="ENGAGEM home page concept: poster-scale typography direction." fonts={fonts} themeColor="#0b0b0d" scheme="dark">
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="site-header">
    <a class="wordmark" href="#">{WORDMARK}</a>
    <nav class="nav" aria-label="Primary">
      <ul>{NAV.map((i) => <li><a href="#">{i}</a></li>)}</ul>
    </nav>
    <a class="cta" href="#">{CTA}</a>
  </header>

  <main id="main">
    <section class="hero">
      <h1 class="poster"><span class="poster__word">ENGAGE</span> <span class="poster__rest">your market.</span></h1>
      <div class="hero__meta">
        <p class="hero__support">{HERO.support}</p>
        <a class="cta cta--hero" href="#">{CTA}</a>
      </div>
    </section>

    <section class="trust" aria-labelledby="trust-cap">
      <p class="trust__caption" id="trust-cap">{MARQUEE_CAPTION}</p>
      <Marquee />
    </section>

    <section class="why" aria-labelledby="why-h">
      <h2 id="why-h">{WHY.h2}</h2>
      <ul class="benefits">
        {WHY.benefits.map((b, idx) => (
          <li>
            <span class="idx" aria-hidden="true">{String(idx + 1).padStart(2, "0")}</span>
            <div><h3>{b.heading}</h3><p>{b.body}</p></div>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <style is:global>
    :root { --bg: #0b0b0d; --fg: #f6f5f2; --green: #18d794; --dim: #9a9a97; }
    body { background: var(--bg); color: var(--fg);
      font-family: "Archivo", system-ui, sans-serif; line-height: 1.4; }
    .site-header { display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem 1.75rem;
      padding: 1.3rem clamp(1.25rem, 5vw, 4rem); border-bottom: 1px solid #26262a; }
    .wordmark { font-weight: 900; font-size: 1.25rem; letter-spacing: 0.02em;
      text-decoration: none; margin-right: auto; }
    .nav ul { list-style: none; display: flex; flex-wrap: wrap; gap: 1.2rem; padding: 0; }
    .nav a { text-decoration: none; font-weight: 600; font-size: 0.85rem; color: var(--dim);
      text-transform: uppercase; letter-spacing: 0.08em; }
    .nav a:hover { color: var(--fg); }
    .cta { text-decoration: none; font-weight: 800; font-size: 0.9rem; background: var(--green);
      color: var(--bg); padding: 0.65rem 1.3rem; transition: filter 150ms ease; }
    .cta:hover { filter: brightness(1.1); }

    main { max-width: 1320px; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 4rem); }

    .hero { padding: clamp(2.5rem, 6vw, 5rem) 0 clamp(3rem, 7vw, 5rem); }
    .poster { font-weight: 900; line-height: 0.82; letter-spacing: -0.04em; margin-bottom: 2.5rem; }
    .poster__word { display: block; font-size: clamp(4.5rem, 23vw, 18rem);
      color: var(--green); }
    .poster__rest { display: block; font-size: clamp(2.4rem, 11vw, 8.5rem);
      font-style: italic; font-family: "Playfair Display", serif; font-weight: 600;
      letter-spacing: -0.01em; }
    .hero__meta { display: grid; gap: 1.5rem 3rem; grid-template-columns: 1fr; align-items: end;
      border-top: 1px solid #26262a; padding-top: 2rem; }
    .hero__support { font-family: "Playfair Display", serif; font-size: clamp(1.15rem, 2.6vw, 1.6rem);
      max-width: 44ch; color: #d9d8d4; }
    .cta--hero { justify-self: start; font-size: 1.1rem; padding: 1rem 2rem; }
    @media (min-width: 880px) { .hero__meta { grid-template-columns: 1fr auto; } }

    .trust { padding: clamp(3rem, 7vw, 4.5rem) 0; border-block: 1px solid #26262a;
      text-align: center; }
    .trust__caption { font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em;
      font-size: 0.82rem; color: var(--dim); margin-bottom: 2rem; }
    .trust .mark { --mark-color: var(--fg); --mark-opacity: 0.4; --mark-size: 42px; }

    .why { padding: clamp(3.5rem, 9vw, 6rem) 0 clamp(4.5rem, 11vw, 8rem); }
    h2 { font-weight: 900; font-size: clamp(2.2rem, 7vw, 4.5rem); line-height: 0.94;
      letter-spacing: -0.03em; margin-bottom: clamp(2.25rem, 5vw, 3.25rem); max-width: 13ch; }
    .benefits { list-style: none; padding: 0; display: grid; gap: 0; grid-template-columns: 1fr; }
    .benefits li { display: flex; gap: 1.25rem; padding: 1.75rem 0;
      border-top: 1px solid #26262a; }
    .benefits li:last-child { border-bottom: 1px solid #26262a; }
    .idx { font-weight: 800; font-size: 1.05rem; color: var(--green);
      flex: 0 0 auto; min-width: 2.5rem; }
    .benefits h3 { font-weight: 800; font-size: 1.5rem; margin-bottom: 0.4rem; }
    .benefits p { color: var(--dim); max-width: 52ch; }
    @media (min-width: 760px) { .benefits li { gap: 2.5rem; } .idx { min-width: 4rem; } }
  </style>
</ConceptLayout>
