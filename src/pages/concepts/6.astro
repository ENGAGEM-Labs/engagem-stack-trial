---
import ConceptLayout from "../../layouts/ConceptLayout.astro";
import Marquee from "../../components/Marquee.astro";
import { WORDMARK, NAV, CTA, HERO, MARQUEE_CAPTION, WHY } from "../../data/concept.js";
const fonts = [
  "https://fonts.googleapis.com/css2?family=Lexend+Mega:wght@700;800;900&family=Public+Sans:wght@400;600;700;800&display=swap",
];
---
<ConceptLayout title="ENGAGEM Concept 6: Neubrutalism" description="ENGAGEM home page concept: neubrutalist direction." fonts={fonts} themeColor="#fbfbf4">
  <a class="skip-link" href="#main">Skip to content</a>
  <header class="site-header">
    <a class="wordmark" href="#">{WORDMARK}</a>
    <nav class="nav" aria-label="Primary">
      <ul>{NAV.map((i) => <li><a href="#">{i}</a></li>)}</ul>
    </nav>
    <a class="cta" href="#">{CTA}</a>
  </header>

  <main id="main">
    <section class="hero">
      <p class="eyebrow">Moncton NB. 20 years. No fluff.</p>
      <h1><span class="hl">ENGAGE</span> your market.</h1>
      <p class="hero__support">{HERO.support}</p>
      <a class="cta cta--hero" href="#">{CTA}</a>
    </section>

    <section class="trust" aria-labelledby="trust-cap">
      <p class="trust__caption" id="trust-cap">{MARQUEE_CAPTION}</p>
      <Marquee />
    </section>

    <section class="why" aria-labelledby="why-h">
      <h2 id="why-h">{WHY.h2}</h2>
      <ul class="benefits">
        {WHY.benefits.map((b, idx) => (
          <li>
            <span class="badge" aria-hidden="true">{idx + 1}</span>
            <h3>{b.heading}</h3>
            <p>{b.body}</p>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <style is:global>
    :root { --black: #10161a; --green: #18d794; --paper: #fbfbf4; --lime: #d7fbec; }
    body { background: var(--paper); color: var(--black);
      font-family: "Public Sans", system-ui, sans-serif; line-height: 1.5; }
    .site-header { display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem 1.75rem;
      padding: 1.2rem clamp(1.25rem, 5vw, 3.5rem); border-bottom: 4px solid var(--black);
      background: var(--paper); }
    .wordmark { font-family: "Lexend Mega", sans-serif; font-weight: 900; font-size: 1.2rem;
      letter-spacing: -0.02em; text-decoration: none; margin-right: auto; }
    .nav ul { list-style: none; display: flex; flex-wrap: wrap; gap: 0.6rem; padding: 0; }
    .nav a { text-decoration: none; font-weight: 700; font-size: 0.85rem; color: var(--black);
      padding: 0.35rem 0.7rem; border: 2px solid transparent; }
    .nav a:hover { border-color: var(--black); background: var(--green); }
    .cta { font-family: "Public Sans", sans-serif; text-decoration: none; font-weight: 800;
      font-size: 0.9rem; background: var(--green); color: var(--black);
      padding: 0.65rem 1.2rem; border: 3px solid var(--black); box-shadow: 4px 4px 0 var(--black);
      transition: transform 120ms ease, box-shadow 120ms ease; }
    .cta:hover { transform: translate(-2px, -2px); box-shadow: 6px 6px 0 var(--black); }
    .cta:active { transform: translate(2px, 2px); box-shadow: 1px 1px 0 var(--black); }

    main { max-width: 1180px; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 3.5rem); }

    .hero { padding: clamp(3rem, 8vw, 6rem) 0 clamp(3rem, 7vw, 5rem); }
    .eyebrow { display: inline-block; font-weight: 800; font-size: 0.85rem;
      text-transform: uppercase; letter-spacing: 0.04em; background: var(--black);
      color: var(--paper); padding: 0.4rem 0.9rem; margin-bottom: 1.75rem; }
    h1 { font-family: "Lexend Mega", sans-serif; font-weight: 900;
      font-size: clamp(2.6rem, 10vw, 6.5rem); line-height: 0.94; letter-spacing: -0.04em;
      max-width: 15ch; }
    .hl { background: var(--green); box-shadow: 0.15em 0 0 var(--green), -0.15em 0 0 var(--green);
      box-decoration-break: clone; -webkit-box-decoration-break: clone; }
    .hero__support { font-size: clamp(1.1rem, 2.4vw, 1.45rem); max-width: 42ch; font-weight: 600;
      margin: 1.75rem 0 2.5rem; }
    .cta--hero { display: inline-block; font-size: 1.15rem; padding: 1rem 2rem;
      box-shadow: 6px 6px 0 var(--black); }

    .trust { padding: clamp(2.5rem, 6vw, 4rem) 0; border-block: 4px solid var(--black);
      text-align: center; background: var(--lime); }
    .trust__caption { font-weight: 800; text-transform: uppercase; letter-spacing: 0.04em;
      margin-bottom: 1.75rem; font-size: 0.95rem; }
    .trust .mark { --mark-color: var(--black); --mark-opacity: 0.62; --mark-size: 44px; }

    .why { padding: clamp(3.5rem, 9vw, 6.5rem) 0 clamp(4.5rem, 11vw, 8rem); }
    h2 { font-family: "Lexend Mega", sans-serif; font-weight: 900; font-size: clamp(1.9rem, 6vw, 3.4rem);
      line-height: 0.98; letter-spacing: -0.03em; margin-bottom: clamp(2rem, 5vw, 3rem); max-width: 14ch; }
    .benefits { list-style: none; padding: 0; display: grid; gap: 1.75rem; grid-template-columns: 1fr; }
    .benefits li { background: #fff; border: 3px solid var(--black); padding: 1.75rem;
      box-shadow: 7px 7px 0 var(--green); }
    .badge { display: inline-grid; place-items: center; width: 44px; height: 44px;
      background: var(--black); color: var(--paper); font-family: "Lexend Mega", sans-serif;
      font-weight: 900; font-size: 1.2rem; margin-bottom: 1rem; }
    .benefits h3 { font-weight: 800; font-size: 1.45rem; margin-bottom: 0.5rem; }
    .benefits p { font-weight: 500; }
    @media (min-width: 860px) { .benefits { grid-template-columns: repeat(3, 1fr); gap: 2rem; } }
  </style>
</ConceptLayout>
