---
import ConceptLayout from "../../layouts/ConceptLayout.astro";
import Marquee from "../../components/Marquee.astro";
import { WORDMARK, NAV, CTA, HERO, MARQUEE_CAPTION, WHY } from "../../data/concept.js";
const fonts = [
  "https://fonts.googleapis.com/css2?family=Lora:ital,wght@0,500;0,600;1,500&family=Raleway:wght@400;500;600;700&display=swap",
];
---
<ConceptLayout title="ENGAGEM Concept 4: Nature Distilled" description="ENGAGEM home page concept: biophilic calm direction." fonts={fonts} themeColor="#f4f7f1">
  <a class="skip-link" href="#main">Skip to content</a>
  <div class="bloom" aria-hidden="true"></div>
  <header class="site-header">
    <a class="wordmark" href="#">{WORDMARK}</a>
    <nav class="nav" aria-label="Primary">
      <ul>{NAV.map((i) => <li><a href="#">{i}</a></li>)}</ul>
    </nav>
    <a class="cta" href="#">{CTA}</a>
  </header>

  <main id="main">
    <section class="hero">
      <p class="eyebrow">Systems that grow quietly</p>
      <h1>{HERO.h1}</h1>
      <p class="hero__support">{HERO.support}</p>
      <a class="cta cta--hero" href="#">{CTA}</a>
    </section>

    <section class="trust" aria-labelledby="trust-cap">
      <Marquee />
      <p class="trust__caption" id="trust-cap">{MARQUEE_CAPTION}</p>
    </section>

    <section class="why" aria-labelledby="why-h">
      <h2 id="why-h">{WHY.h2}</h2>
      <ul class="benefits">
        {WHY.benefits.map((b) => (
          <li>
            <span class="seed" aria-hidden="true"></span>
            <h3>{b.heading}</h3>
            <p>{b.body}</p>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <style is:global>
    :root { --ink: #0d3a4e; --green: #18d794; --green-deep: #0f9e6e;
      --paper: #f4f7f1; --slate: #4c5f5a; }
    body { background: var(--paper); color: var(--ink);
      font-family: "Raleway", system-ui, sans-serif; line-height: 1.6; position: relative;
      overflow-x: hidden; }
    .bloom { position: absolute; inset: 0; z-index: 0; pointer-events: none;
      background:
        radial-gradient(38% 30% at 82% 8%, rgba(24,215,148,0.28), transparent 70%),
        radial-gradient(34% 26% at 6% 30%, rgba(13,58,78,0.12), transparent 70%),
        radial-gradient(40% 34% at 92% 78%, rgba(24,215,148,0.16), transparent 72%); }
    header, main { position: relative; z-index: 1; }

    .site-header { display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem 2rem;
      max-width: 1160px; margin: 0 auto; padding: 1.6rem clamp(1.25rem, 5vw, 4rem); }
    .wordmark { font-family: "Lora", serif; font-weight: 600; font-size: 1.4rem;
      letter-spacing: 0.06em; text-decoration: none; margin-right: auto; }
    .nav ul { list-style: none; display: flex; flex-wrap: wrap; gap: 1.4rem; padding: 0; }
    .nav a { text-decoration: none; font-weight: 500; font-size: 0.95rem; color: var(--slate); }
    .nav a:hover { color: var(--green-deep); }
    .cta { text-decoration: none; font-weight: 700; font-size: 0.95rem; background: var(--ink);
      color: var(--paper); padding: 0.72rem 1.5rem; border-radius: 999px;
      transition: background 150ms ease; }
    .cta:hover { background: var(--green-deep); }

    main { max-width: 1160px; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 4rem); }

    .hero { padding: clamp(3.5rem, 10vw, 8rem) 0 clamp(3rem, 8vw, 6rem); max-width: 22ch; }
    .eyebrow { font-weight: 600; font-size: 0.82rem; text-transform: uppercase;
      letter-spacing: 0.2em; color: var(--green-deep); margin-bottom: 1.5rem; }
    h1 { font-family: "Lora", serif; font-weight: 600; font-size: clamp(3rem, 10vw, 6.5rem);
      line-height: 1.02; letter-spacing: -0.015em; }
    h1 { max-width: none; }
    .hero__support { font-size: clamp(1.1rem, 2.3vw, 1.4rem); max-width: 42ch;
      margin: 1.75rem 0 2.5rem; color: #375049; font-weight: 400; }
    .cta--hero { display: inline-block; font-size: 1.1rem; padding: 1rem 2.1rem; }

    .trust { padding: clamp(3rem, 7vw, 5rem) 0; text-align: center; }
    .trust .mark { --mark-color: var(--green-deep); --mark-opacity: 0.55; --mark-size: 40px; }
    .trust__caption { font-family: "Lora", serif; font-style: italic; font-size: 1.2rem;
      color: var(--slate); margin-top: 1.75rem; }

    .why { padding: clamp(3rem, 8vw, 6rem) 0 clamp(4.5rem, 11vw, 8rem); }
    h2 { font-family: "Lora", serif; font-weight: 600; font-size: clamp(2rem, 5.5vw, 3.3rem);
      line-height: 1.05; margin-bottom: clamp(2.25rem, 5vw, 3.25rem); max-width: 15ch; }
    .benefits { list-style: none; padding: 0; display: grid; gap: 1.5rem;
      grid-template-columns: 1fr; }
    .benefits li { background: rgba(255,255,255,0.7); border: 1px solid rgba(15,158,110,0.22);
      padding: 2rem; border-radius: 28px 28px 28px 6px;
      -webkit-backdrop-filter: none; }
    .seed { display: block; width: 48px; height: 48px; margin-bottom: 1.1rem;
      background: var(--green); border-radius: 50% 50% 50% 8px; transform: rotate(-8deg); }
    .benefits h3 { font-family: "Lora", serif; font-weight: 600; font-size: 1.4rem;
      margin-bottom: 0.5rem; }
    .benefits p { color: var(--slate); }
    @media (min-width: 860px) { .benefits { grid-template-columns: repeat(3, 1fr); gap: 1.75rem; } }
  </style>
</ConceptLayout>
