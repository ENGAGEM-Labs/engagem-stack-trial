---
import ConceptLayout from "../../layouts/ConceptLayout.astro";
import Marquee from "../../components/Marquee.astro";
import { WORDMARK, NAV, CTA, HERO, MARQUEE_CAPTION, WHY } from "../../data/concept.js";
const fonts = [
  "https://fonts.googleapis.com/css2?family=Lexend:wght@400;500;600;700;800&family=Source+Sans+3:wght@400;500;600&display=swap",
];
---
<ConceptLayout title="ENGAGEM Concept 3: Trust & Authority" description="ENGAGEM home page concept: trust and authority direction." fonts={fonts} themeColor="#07344d">
  <a class="skip-link" href="#main">Skip to content</a>
  <div class="top">
    <header class="site-header">
      <a class="wordmark" href="#">{WORDMARK}</a>
      <nav class="nav" aria-label="Primary">
        <ul>{NAV.map((i) => <li><a href="#">{i}</a></li>)}</ul>
      </nav>
      <a class="cta" href="#">{CTA}</a>
    </header>

    <section class="hero" id="main-anchor">
      <p class="eyebrow">Twenty years of evidence <span class="hair"></span> Maritimes</p>
      <h1>{HERO.h1}</h1>
      <p class="hero__support">{HERO.support}</p>
      <a class="cta cta--hero" href="#">{CTA}</a>
    </section>
  </div>

  <main id="main">
    <section class="trust" aria-labelledby="trust-cap">
      <p class="trust__caption" id="trust-cap">{MARQUEE_CAPTION}</p>
      <Marquee />
    </section>

    <section class="why" aria-labelledby="why-h">
      <h2 id="why-h">{WHY.h2}</h2>
      <ul class="benefits">
        {WHY.benefits.map((b) => (
          <li>
            <span class="tick" aria-hidden="true">
              <svg viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/></svg>
            </span>
            <div>
              <h3>{b.heading}</h3>
              <p>{b.body}</p>
            </div>
          </li>
        ))}
      </ul>
    </section>
  </main>

  <style is:global>
    :root { --ink: #07344d; --ink-deep: #062a3e; --green: #18d794;
      --paper: #ffffff; --slate: #4a5c65; --hair: rgba(255,255,255,0.22); }
    body { background: var(--paper); color: var(--ink);
      font-family: "Source Sans 3", system-ui, sans-serif; line-height: 1.55; }

    .top { background: var(--ink); color: #eaf3f5; }
    .site-header { display: flex; flex-wrap: wrap; align-items: center; gap: 0.75rem 2rem;
      max-width: 1200px; margin: 0 auto;
      padding: 1.4rem clamp(1.25rem, 5vw, 4rem); border-bottom: 1px solid var(--hair); }
    .wordmark { font-family: "Lexend", sans-serif; font-weight: 800; font-size: 1.35rem;
      letter-spacing: 0.04em; text-decoration: none; margin-right: auto; color: #fff; }
    .nav ul { list-style: none; display: flex; flex-wrap: wrap; gap: 1.4rem; padding: 0; }
    .nav a { text-decoration: none; font-weight: 500; font-size: 0.95rem;
      color: #b9cdd4; }
    .nav a:hover { color: var(--green); }
    .cta { font-family: "Lexend", sans-serif; text-decoration: none; font-weight: 700;
      font-size: 0.95rem; background: var(--green); color: var(--ink-deep);
      padding: 0.72rem 1.4rem; border-radius: 6px; transition: filter 150ms ease; }
    .cta:hover { filter: brightness(1.08); }

    .hero { max-width: 1200px; margin: 0 auto;
      padding: clamp(3.5rem, 10vw, 8rem) clamp(1.25rem, 5vw, 4rem) clamp(4rem, 11vw, 9rem); }
    .eyebrow { font-family: "Lexend", sans-serif; font-weight: 600; font-size: 0.82rem;
      text-transform: uppercase; letter-spacing: 0.18em; color: var(--green);
      display: flex; align-items: center; gap: 0.9rem; margin-bottom: 1.6rem; }
    .eyebrow .hair { width: 46px; height: 1px; background: var(--hair); }
    h1 { font-family: "Lexend", sans-serif; font-weight: 800;
      font-size: clamp(3rem, 10vw, 7rem); line-height: 0.98; letter-spacing: -0.03em;
      color: #fff; max-width: 15ch; }
    .hero__support { font-size: clamp(1.1rem, 2.3vw, 1.45rem); max-width: 44ch;
      margin: 1.75rem 0 2.5rem; color: #cadde3; }
    .cta--hero { display: inline-block; font-size: 1.1rem; padding: 1rem 2rem; }

    main { max-width: 1200px; margin: 0 auto; padding: 0 clamp(1.25rem, 5vw, 4rem); }

    .trust { padding: clamp(3rem, 7vw, 5rem) 0; text-align: center; }
    .trust__caption { font-family: "Lexend", sans-serif; font-weight: 600;
      font-size: 0.82rem; text-transform: uppercase; letter-spacing: 0.16em;
      color: var(--slate); margin-bottom: 2rem; }
    .trust .mark { --mark-color: var(--ink); --mark-opacity: 0.4; --mark-size: 40px; }

    .why { padding: clamp(2rem, 5vw, 3rem) 0 clamp(4.5rem, 11vw, 8rem);
      border-top: 1px solid #e2e8ea; }
    h2 { font-family: "Lexend", sans-serif; font-weight: 800;
      font-size: clamp(2rem, 5.5vw, 3.3rem); line-height: 1.02; letter-spacing: -0.02em;
      margin: clamp(2.5rem, 6vw, 3.5rem) 0 clamp(2rem, 5vw, 3rem); max-width: 16ch; }
    .benefits { list-style: none; padding: 0; display: grid; gap: 1.5rem;
      grid-template-columns: 1fr; }
    .benefits li { display: flex; gap: 1.1rem; align-items: flex-start;
      padding: 1.75rem; background: #f4f8f8; border-radius: 12px;
      border: 1px solid #e2e8ea; }
    .tick { flex: 0 0 auto; width: 40px; height: 40px; display: grid; place-items: center;
      background: var(--green); color: var(--ink-deep); border-radius: 8px; }
    .tick svg { width: 22px; height: 22px; }
    .benefits h3 { font-family: "Lexend", sans-serif; font-weight: 700; font-size: 1.3rem;
      margin-bottom: 0.4rem; }
    .benefits p { color: var(--slate); }
    @media (min-width: 860px) { .benefits { grid-template-columns: repeat(3, 1fr); gap: 1.75rem; } }
  </style>
</ConceptLayout>
